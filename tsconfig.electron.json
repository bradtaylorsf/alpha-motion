{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "electron-dist",
    "rootDir": "electron",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["node_modules"]
}
