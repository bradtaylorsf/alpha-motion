{
  "name": "remotion-moodboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "concurrently --kill-others --kill-signal SIGTERM -n api,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch --env-file=.env src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && esbuild src/server/index.ts --bundle --platform=node --format=esm --outfile=dist/server/index.js --packages=external --banner:js=\"import { fileURLToPath } from 'url'; import { dirname } from 'path'; const __filename = fileURLToPath(import.meta.url); const __dirname = dirname(__filename);\"",
    "preview": "vite preview",
    "remotion:studio": "remotion studio",
    "remotion:render": "remotion render",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production node dist/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@babel/standalone": "^7.26.0",
    "@google/genai": "^1.38.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@remotion/bundler": "4.0.409",
    "@remotion/cli": "4.0.409",
    "@remotion/google-fonts": "4.0.409",
    "@remotion/lottie": "4.0.409",
    "@remotion/player": "4.0.409",
    "@remotion/shapes": "4.0.409",
    "@remotion/three": "4.0.409",
    "@remotion/transitions": "4.0.409",
    "@tanstack/react-query": "^5.60.0",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "lucide-react": "^0.468.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-resizable-panels": "^4.5.2",
    "react-router-dom": "^7.13.0",
    "remotion": "4.0.409",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "three": "^0.170.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/babel__standalone": "^7.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/three": "^0.170.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.27.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
